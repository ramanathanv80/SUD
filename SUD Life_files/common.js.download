$(document).ready(function () {
    //for SI patment methods
    $(".selectSImethod_optn").click(function () {
        $(".selectSImethod_optn").removeClass("selectSImethod_optn_Active");
        $(this).addClass("selectSImethod_optn_Active");
    });

    ///////////////////////////////////////////////////////////////////////////////////////////////////////////////
    ///// NEW DESIGN SCRIPT STARTS FROM HERE
    ///// AS ON 17012025 BY NITINJ
    //////////////////////////////////////////////////////////////////////////////////////////////////////////////

    //for Header menu active 
    //To Show/Hide main menu on page scroll
    $(".HeaderMenu .navbar-nav").hide();
    var menuMedia = window.matchMedia("(min-width: 768px)")
    mainMenu(menuMedia)
    menuMedia.addListener(mainMenu)
    function mainMenu(menuMedia) {
        if (menuMedia.matches) {
            $(window).scroll(function () {
                var scroll = $(window).scrollTop();

                if (scroll >= 80) {
                    $(".HeaderMenu .navbar-nav").show();
                }
                else {
                    $(".HeaderMenu .navbar-nav").hide();
                }
            });
        }
    }

    $(".HeaderMenu .nav-link").click(function () {
        $(".HeaderMenu .nav-link").removeClass("active");
        $(this).addClass("active");
    })
    $(".navbar-toggler").click(function () {
        $(this).parents(".HeaderMenu").toggleClass("MenuActive");
        if ($(".HeaderMenu").hasClass("MenuActive")) {
            $("body").css("overflow", "hidden");
        } else {
            $("body").css("overflow", "visible");
        }
    })

    //to show/hide fixed footer on PrdtSelect page
    $(".GetPremium_FooterHead").click(function () {
        $(".GetPremium_FooterCntnt").toggle();
        $(".GetPremium_FooterHead .fa").toggleClass("fa-angle-down").toggleClass("fa-angle-up");
    });
    //to change the fixed footer place in mobile
    if ($(window).width() <= 767) {
        $(".PlanSelectPg .FixedFooter").insertBefore($(".WhatIsPlan_Sect_new"));
    }

    //to add class to input field and green border if it has value
    $('.InputDiv > input, .InputDiv > .YourNameRow input, .InputDiv > .YourEmailRow input, .InputDivNoLabel input').each(function () {
        let val = $(this).val().trim();
        if (val !== '' && val !== '0') {
            $(this).closest('.InputDiv').addClass('inputFilled');
            $(this).closest('.InputDivNoLabel').addClass('inputFilled');

            if ($(this).parents(".InputDiv").find(".YourNameRow").hasClass("YourNameRow")) {
                $(this).closest('.InputDiv').removeClass('inputFilled');
                $(this).closest(".YourNameRow").addClass('inputFilled');
            }

            if ($(this).parents(".InputDiv").find(".YourEmailRow").hasClass("YourEmailRow")) {
                $(this).closest('.InputDiv').removeClass('inputFilled');
                $(this).closest(".YourEmailRow").addClass('inputFilled');
            }
        }
    });
    $('.InputDiv > input, .InputDiv > .YourNameRow input, .InputDiv > .YourEmailRow input, .InputDivNoLabel input').on('input', function () {
        let val = $(this).val().trim();
        if (val !== '' && val !== '0') {
            $(this).closest('.InputDiv').addClass('inputFilled');
            $(this).closest('.InputDivNoLabel').addClass('inputFilled');

            if ($(this).parents(".InputDiv").find(".YourNameRow").hasClass("YourNameRow")) {
                $(this).closest('.InputDiv').removeClass('inputFilled');
                $(this).closest(".YourNameRow").addClass('inputFilled');
            }

            if ($(this).parents(".InputDiv").find(".YourEmailRow").hasClass("YourEmailRow")) {
                $(this).closest('.InputDiv').removeClass('inputFilled');
                $(this).closest(".YourEmailRow").addClass('inputFilled');
            }

        } else {
            $(this).closest('.InputDiv').removeClass('inputFilled');
            $(this).closest('.InputDivNoLabel').removeClass('inputFilled');
            $(this).closest(".YourNameRow").removeClass('inputFilled');
            $(this).closest(".YourEmailRow").removeClass('inputFilled');
        }
    });


    $('.BrdrLabelInpDiv input').each(function () {
        let val = $(this).val().trim();
        if (val !== '' && val !== '0') {
            $(this).closest('.BrdrLabelInpDiv').addClass('inputFilled');
        }
    });
    $('.BrdrLabelInpDiv input').on('input', function () {
        let val = $(this).val().trim();
        if (val !== '' && val !== '0') {
            $(this).closest('.BrdrLabelInpDiv').addClass('inputFilled');
        } else {
            $(this).closest('.BrdrLabelInpDiv').removeClass('inputFilled');
        }
    });

    // for dropdown
    $('.BrdrLabelInpDiv .InputField .CustSelect__trigger span, .CustSelectMainDiv .CustSelect__trigger span').each(function () {
        let text = $(this).text().trim().toLowerCase();
        let $trigger = $(this).closest('.CustSelect__trigger');
        let $brdrDiv = $trigger.closest('.BrdrLabelInpDiv');
        let $mainDiv = $trigger.closest('.CustSelectMainDiv');

        if (text !== '' && !text.includes('select')) {
            if ($brdrDiv.length) {
                $brdrDiv.addClass('inputFilled');
            } else if ($mainDiv.length) {
                $mainDiv.addClass('inputFilled');
            }
        }
    });
    $('.BrdrLabelInpDiv .InputField .CustSelectInDiv').on('click', function () {
        let span = $(this).find('span');
        setTimeout(() => { // Delay to wait for content update
            if (span.text().trim() !== '') {
                span.parents('.BrdrLabelInpDiv').addClass('inputFilled');
            } else {
                span.parents('.BrdrLabelInpDiv').removeClass('inputFilled');
            }
        }, 10);
    });
    $('.CustSelectMainDiv .CustSelectInDiv').on('click', function () {
        let $span = $(this).find('span');
        let $mainDiv = $(this).closest('.CustSelectMainDiv');
        setTimeout(() => { // Delay to wait for content update
            let text = $span.text().trim().toLowerCase();

            if (text !== '' && !text.includes('select')) {
                if ($mainDiv.length) {
                    $mainDiv.addClass('inputFilled');
                }
            }
        }, 10);
    });

    //$('.BrdrLabelInpDiv .InputField .CustSelectInDiv').on('focus', function () {
    //    let span = $(this).find('span');
    //    setTimeout(() => { // Delay to wait for content update
    //        if (span.text().trim() !== '') {
    //            span.parents('.BrdrLabelInpDiv').addClass('inputFilled');
    //        } else {
    //            span.parents('.BrdrLabelInpDiv').removeClass('inputFilled');
    //        }
    //    }, 10);
