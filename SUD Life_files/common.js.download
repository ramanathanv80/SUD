    //for Why Choose SUD Life scroll
    function enableDragScroll(element) {
        let isDown = false;
        let startX;
        let scrollLeft;

        element.addEventListener('mousedown', (e) => {
            isDown = true;
            element.classList.add('active');
            startX = e.pageX - element.offsetLeft;
            scrollLeft = element.scrollLeft;
        });

        element.addEventListener('mouseleave', () => {
            isDown = false;
            element.classList.remove('active');
        });

        element.addEventListener('mouseup', () => {
            isDown = false;
            element.classList.remove('active');
        });

        element.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - element.offsetLeft;
            const walk = (x - startX) * 2; // Speed factor
            element.scrollLeft = scrollLeft - walk;
        });
    }

    // Apply to the scrollable container

    const scrollContainer = document.querySelector(".WSL_Cntnr"); // Change to your element
    if (scrollContainer) {
        enableDragScroll(scrollContainer);
    }


    //on plan tab click add active class to itself and its respective content div
    //$('.PlanTabBox_new').on('click', function () {
    //    $('.PlanTabBox_new').removeClass('active');
    //    $(this).addClass('active');
    //});
    $('.PlanTabBox_new, .nav-link').on('click', function () {
        var isCard = $(this).hasClass('PlanTabBox_new');

        if (isCard) {
            // Get the id of the clicked card
            var cardId = $(this).attr('id');
            // Find the corresponding nav-link id
            var contentId = cardId.replace('PTBN', 'menuLink');
        } else {
            // Get the id of the clicked nav-link
            var contentId = $(this).attr('id');
            // Find the corresponding card id
            var cardId = contentId.replace('menuLink', 'PTBN');
        }

        // Remove active class from all link cards and content boxes
        $('.PlanTabBox_new, .nav-link').removeClass('active');

        // Add active class to clicked element and its counterpart
        $('#' + cardId).addClass('active');
        $('#' + contentId).addClass('active');
    });


    //on plan product box click add active class to itself and its respective content div
    $('.PrdtPlanBox').on('click', function () {
        // Get the id of the clicked card
        var cardId = $(this).attr('id');

        // Find the corresponding content box id
        var contentId = cardId.replace('PPB', 'PPBC');

        // Remove the active class from all link cards and content boxes
        $('.PrdtPlanBox').removeClass('active');
        $('.PrdtPlanBoxCntntSect').removeClass('active');

        // Add the active class to the clicked card and its corresponding content box
        $(this).addClass('active');
        $('#' + contentId).addClass('active');
    });

