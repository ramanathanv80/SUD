function setLocalStorage(key, value) {

    localStorage.setItem(key, value);

}



function getLocalStorage(key) {

    return localStorage.getItem(key) || "";

}



function setSessionStorage(key, value) {

    sessionStorage.setItem(key, value);

}



function getSessionStorage(key) {

    return sessionStorage.getItem(key) || "";

}



$(window).on('beforeunload', function () {

    localStorage.removeItem('ic_window_id');

});



function validateCallCenterTab() {

    const windowId = Math.random().toString();


    if (!window.name) {
        window.name = windowId;

        setLocalStorage('ic_window_id', window.name);

        setSessionStorage('ic_window_id', window.name);

        AjaxSessionLogOutCall();
    }

    const CommonWindowId = getLocalStorage('ic_window_id');

    const currentWindowId = getSessionStorage('ic_window_id');



    if (currentWindowId !== CommonWindowId && getLocalStorage('closePreviousTab') == "1") {

        const previousTabWindowId = getLocalStorage('ic_window_id');

        if (previousTabWindowId) {

            localStorage.setItem('redirectTab', '1');

        }

    }



    if (CommonWindowId !== window.name && getLocalStorage('closePreviousTab') != "1") {

        setLocalStorage('ic_window_id', window.name);

        setLocalStorage('closePreviousTab', "1");

        console.log("window name replaced in localStorage");

        clearInterval(validateCallCenterTab);

    }

}



function checkAndRedirectPreviousTab() {

    const CommonWindowId1 = getLocalStorage('ic_window_id');

    const currentWindowId1 = getSessionStorage('ic_window_id');

    if (getLocalStorage('redirectTab') == "1" && currentWindowId1 !== CommonWindowId1) {

        window.name = "";
        window.location.href = '../../Session/SessionTimeOutView';
        localStorage.removeItem('redirectTab');
    }

}



setInterval(checkAndRedirectPreviousTab, 1000);



const callCenterInterval = setInterval(validateCallCenterTab, 3000);

(function (window, $) {

    function initEmailAutocomplete(selectors) {

        const domains = ['gmail.com', 'yahoo.com', 'outlook.com', 'hotmail.com', 'live.com', 'icloud.com'];
        let $suggestBox = null;
        let activeIndex = -1;
        let lastInput = null;

        function ensureSuggestBox() {
            if ($suggestBox) return $suggestBox;

            $suggestBox = $('<div class="email-suggest-box" style="display:none;"></div>');
            $('body').append($suggestBox);
            return $suggestBox;
        }

        function getViewportRect($input) {
            return $input[0].getBoundingClientRect();
        }

        function buildItems(localPart) {
            return domains.map(d => ({ text: localPart + '@@' + d, domain: d }));
        }

        function measureBox($box, widthPx) {
            const prev = {
                display: $box.css('display'),
                visibility: $box.css('visibility'),
                top: $box.css('top'),
                left: $box.css('left'),
                width: $box.css('width')
            };

            $box.css({
                display: 'block',
                visibility: 'hidden',
                top: '-9999px',
                left: '-9999px',
                width: widthPx + 'px'
            });

            const size = { w: $box.outerWidth(), h: $box.outerHeight() };
            $box.css(prev);
            return size;
        }

        function positionBox($input) {
            const rect = getViewportRect($input);
            const $box = ensureSuggestBox();

            const desiredWidth = Math.max($input.outerWidth(), 240);
            const width = Math.min(desiredWidth, window.innerWidth - 16);
            const size = measureBox($box, width);

            const spaceBelow = window.innerHeight - rect.bottom;
            const spaceAbove = rect.top;

            let top = (spaceBelow >= size.h + 8)
                ? rect.bottom + 4
                : Math.max(4, rect.top - size.h - 4);

            let left = Math.min(rect.left, window.innerWidth - width - 4);
            left = Math.max(4, left);

            $box.css({
                position: 'fixed',
                top: top + 'px',
                left: left + 'px',
                width: width + 'px',
                display: 'block',
                visibility: 'visible'
            });
        }

        function hideBox() {
            if ($suggestBox) $suggestBox.hide().empty();
            activeIndex = -1;
            lastInput = null;
        }

        function applySelection($input, domain) {
            const val = $input.val();
            const atIdx = val.indexOf('@');
            if (atIdx === -1) return;

            const local = val.substring(0, atIdx);
            $input.val(local + '@' + domain);
            hideBox();
        }

        function renderBox($input, localPart, filter) {
            const items = buildItems(localPart)
                .filter(x => !filter || x.domain.startsWith(filter));

            if (!items.length) {
                hideBox();
                return;
            }

            const $box = ensureSuggestBox();
            $box.empty();
            activeIndex = -1;

            items.forEach(item => {
                const $it = $(`
                    <div class="email-suggest-item float-start w-100">
                        <span class="local float-start">${localPart}@</span>
                        <span class="domain float-start">${item.domain}</span>
                    </div>
                `);

                $it.data('domain', item.domain);
                $it.on('mousedown', e => {
                    e.preventDefault();
                    applySelection($input, item.domain);
                });

                $box.append($it);
            });

            lastInput = $input[0];
            positionBox($input);
        }

        function handleInput($input) {
            const val = $input.val();
            const atIdx = val.indexOf('@');

            if (atIdx === -1 || val.indexOf(' ') >= 0) {
                hideBox();
                return;
            }

            const local = val.substring(0, atIdx);
            const domainPart = val.substring(atIdx + 1);
            renderBox($input, local, domainPart);
        }

        function attach(selector) {
            const $input = $(selector);
            if (!$input.length) return;

            $input
                .on('input focus', () => handleInput($input))
                .on('blur', () => setTimeout(hideBox, 150))
                .on('keydown', function (e) {
                    if (!$suggestBox || $suggestBox.is(':hidden')) return;

                    const $items = $suggestBox.children('.email-suggest-item');
                    if (!$items.length) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % $items.length;
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + $items.length) % $items.length;
                    } else if (e.key === 'Enter') {
                        //If user presses Enter without arrow keys, this will break:$items.eq(activeIndex)
                        e.preventDefault();
                        const idx = activeIndex >= 0 ? activeIndex : 0;
                        applySelection($input, $items.eq(idx).data('domain'));
                    } else if (e.key === 'Escape') {
                        hideBox();
                    }

                    $items.removeClass('active')
                        .eq(activeIndex).addClass('active');
                });
        }

        $(window).on('scroll resize', function () {
            if ($suggestBox && !$suggestBox.is(':hidden') && lastInput) {
                positionBox($(lastInput));
            }
        });

        selectors.forEach(attach);
    }

    // expose globally
    window.initEmailAutocomplete = initEmailAutocomplete;

})(window, jQuery);



$(document).ready(function () {
    const iframe = document.getElementById("chatbot-iframe");

    iframe.addEventListener("load", () => {
        try {
            const doc = iframe.contentDocument || iframe.contentWindow.document;
            const toggleBtn = doc.querySelector("#chat-toggle");

            if (!toggleBtn) {
                console.warn("Chatbot toggle button not found inside iframe");
                return;
            }

            // Attach click listener inside iframe
            toggleBtn.addEventListener("click", () => {
                if (toggleBtn.classList.contains("open")) {
                    // Expand when open
                    iframe.style.width = "430px";
                    iframe.style.height = "560px";
                } else {
                    // Collapse when closed
                    iframe.style.width = "85px";
                    iframe.style.height = "85px";
                }
            });
        } catch (err) {
            console.error("Error accessing chatbot iframe:", err);
        }
    });
});

