    // Handle keyboard navigation with up and down arrows
    $(document).on('keydown', '.CustSelectInDiv', function (e) {

        var $dropdown = $(this).find('.CustSelect-optionsDIV');
        var $options = $dropdown.find('.CustSelect-option:not([style*="display: none"])');
        var $selected = $options.filter('.selected');
        var index = $options.index($selected);

        // Enter key press
        if (e.keyCode === 13) {
            e.preventDefault();
        }

        // Down arrow (40)
        if (e.keyCode === 40) {
            e.preventDefault();
            $(this).closest('.BrdrLabelInpDiv').addClass('inputFilled');
            /*var nextIndex = (index + 1) % $options.length;*/
            if (index < $options.length - 1) { // Ensure it doesn't move past the last option
                var nextIndex = index + 1;
                $options.removeClass('selected').eq(nextIndex).addClass('selected');
                $options.eq(nextIndex).focus(); // Optionally focus the new option
                updateSelectedText($(this), $options.eq(nextIndex).text());
                /*$(this).find('.selected').trigger("click");*/
            }
        }

        // Up arrow (38)
        if (e.keyCode === 38) {
            e.preventDefault();
            $(this).closest('.BrdrLabelInpDiv').addClass('inputFilled');
            /*var prevIndex = (index - 1 + $options.length) % $options.length;*/
            if (index > 0) { // Ensure it doesn't move past the first option
                var prevIndex = index - 1;
                $options.removeClass('selected').eq(prevIndex).addClass('selected');
                $options.eq(prevIndex).focus(); // Optionally focus the new option
                updateSelectedText($(this), $options.eq(prevIndex).text());
                /*$(this).find('.selected').trigger("click");*/
            }
        }

        // Capture typed characters (A-Z and 0-9) to select options by typing
        if ((e.keyCode >= 65 && e.keyCode <= 90) || (e.keyCode >= 48 && e.keyCode <= 57)) { // A-Z and 0-9 key codes
            var char;
            if (e.keyCode >= 65 && e.keyCode <= 90) {
                char = String.fromCharCode(e.keyCode).toLowerCase(); // Convert A-Z to lowercase
            } else {
                char = String.fromCharCode(e.keyCode); // Keep 0-9 as they are
            }

            typedCharacters += char;

            clearTimeout(typingTimer);
            typingTimer = setTimeout(function () {
                typedCharacters = ''; // Reset typed characters after a pause
            }, 1000); // 1 second delay to reset typing

            // Find the option that starts with the typed characters
            var matchingOption = $options.filter(function () {
                return $(this).text().toLowerCase().startsWith(typedCharacters);
            }).first();

            if (matchingOption.length > 0) {
                $options.removeClass('selected');
                matchingOption.addClass('selected');
                //alert($('.FocusShadow').length);
                $('.FocusShadow').find('.CustSelect__trigger span').text(matchingOption.text());
                $(this).closest('.BrdrLabelInpDiv').addClass('inputFilled');
                /*matchingOption.trigger("click");*/
                /*updateSelectedText($(this), matchingOption.text());*/


                /*$(this).find('.selected').trigger("click");*/


            }
        }

        var onClickAttr = $(this).find('.selected').attr("onclick");
        eval(onClickAttr);
        /*fnSetHiddenValue(2, '7');*/


    });

    // Helper function to update the selected text in the trigger span
    function updateSelectedText($dropdown, text) {
        $dropdown.find('.CustSelect__trigger span').text(text);
    }

