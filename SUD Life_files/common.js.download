    // When the checkbox is focused, tick the box on Enter
    $('.OnlyChkBoxClikLabel input[type="checkbox"], .ChkBoxCntnr input[type="checkbox"]').on('keydown', function (e) {
        if (e.key === "Enter") {  // Check if the Enter key is pressed
            e.preventDefault(); // Prevent default behavior, like form submission
            // Toggle the checked property
            $(this).prop('checked', !$(this).prop('checked'));
            // Ensure the checkbox retains focus
            $(this).focus();
        }
    });


    // Event listener for keypress on radio buttons for Plan Name
    $('.switch-field input[type="radio"]').on('keypress', function (e) {
        if (e.which === 13) { // Enter key is pressed
            var $currentRadio = $(this);

            // Find the other radio button
            var $otherRadio = $('.switch-field input[name="switch-one"]').not($currentRadio);

            // Toggle checked status
            if ($currentRadio.prop('checked')) {
                $currentRadio.prop('checked', false);
                $otherRadio.prop('checked', true).focus(); // Focus and check the other radio
            } else {
                $currentRadio.prop('checked', true);
                $otherRadio.prop('checked', false);
            }
        }
    });


