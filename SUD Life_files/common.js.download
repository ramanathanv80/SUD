
function ShowMyAccordDiv() {
    // Close all other Acord Div if ShowOnlyMeAccord class is applied
    if ($(".PersonDet .accordion-section").hasClass("ShowOnlyMeAccord")) {
        $(".PersonDet .accordion-section .accordion-section-title").removeClass("active");
        $(".PersonDet .accordion-section .accordion-section-content").removeClass("open");
        $(".PersonDet .accordion-section .accordion-section-content").css("display", "none");
        $(".ShowOnlyMeAccord .accordion-section-title").addClass("active");
        $(".ShowOnlyMeAccord .accordion-section-content").addClass("open");
        $(".ShowOnlyMeAccord .accordion-section-content").css("display", "block");
    }
}

