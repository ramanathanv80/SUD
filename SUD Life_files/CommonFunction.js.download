function fnCalAge(strDOB, ObjAge) {
    var now = new Date();
    var s, bD;
    bD = strDOB.split('-');

    var dd = bD[0];
    var mm = bD[1];
    var yy = bD[2];

    if ((mm != "0") && (dd != "0") && (yy != "0")) {
        if (bD.length == 3) {
            var born = new Date(bD[2], bD[1] * 1 - 1, bD[0]);
            var years = Math.floor((now.getTime() - born.getTime()) / (365.25 * 24 * 60 * 60 * 1000));
            $(ObjAge).val(years);
        }
    }
}

