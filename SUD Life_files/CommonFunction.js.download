function getFormattedDateIn_ddMMYYYY(strDOB) {

    var s, dtDOBSplitVal;
    dtDOBSplitVal = strDOB.split('-');

    var dd = parseInt(dtDOBSplitVal[0]);
    var mm = parseInt(dtDOBSplitVal[1]);
    var yy = parseInt(dtDOBSplitVal[2]);

    if (dd < 10) {
        dd = "0" + dd;
    }
    if (mm < 10) {
        mm = "0" + mm;
    }


    if (yy <= 99) {
        yy = "19" + yy;
    }

    s = dd + "-" + mm + "-" + yy;

    return s;
}

function DisplayDateFormate(dateStr) {
    var outPut = '';

    try {

        if (dateStr.indexOf('T') > -1) {
            var date = dateStr.split('T')[0];
            if (date.indexOf('-') > -1) {
                var dateArr = date.split('-');
                outPut = dateArr[2] + "/" + dateArr[1] + "/" + dateArr[0];
            }
            else if (date.indexOf('/') > -1) {
                var dateArr = date.split('/');
                outPut = dateArr[2] + "/" + dateArr[1] + "/" + dateArr[0];
            }
        }
        else if (dateStr.indexOf(' ') > -1) {
            var date = dateStr.split(' ')[0];
            if (date.indexOf('-') > -1) {
                var dateArr = date.split('-');
                outPut = dateArr[2] + "/" + dateArr[1] + "/" + dateArr[0];
            }
            else if (date.indexOf('/') > -1) {
                var dateArr = date.split('/');
                outPut = dateArr[2] + "/" + dateArr[1] + "/" + dateArr[0];
            }
        }
    } catch (e) {

    }
    return outPut;
}
function parseDateNew(dateStr) {
    console.log(dateStr);
    var dateParts = dateStr.split("-");
    return new Date(dateParts[2], (GetMonthMM(dateParts[1]) - 1), dateParts[0]);
}

function GetMonthMM(month) {
    var mm = month;
    switch (month.toLowerCase()) {
        case "jan":
            mm = "01";
            break;
        case "feb":
            mm = "02";
            break;
        case "mar":
            mm = "03";
            break;
        case "apr":
            mm = "04";
            break;
        case "may":
            mm = "05";
            break;
        case "jun":
            mm = "06";
            break;
        case "jul":
            mm = "07";
            break;
        case "aug":
            mm = "08";
            break;
        case "sep":
            mm = "09";
            break;
        case "oct":
            mm = "10";
            break;
        case "nov":
            mm = "11";
            break;
        case "dec":
            mm = "12";
            break;
    }
    return mm;
}

function GetMonthMMM(month) {
    var mmm = "Jan";
    switch (month) {
        case "01":
        case "1":
            mmm = "Jan";
            break;
        case "02":
        case "2":
            mmm = "Feb";
            break;
        case "03":
        case "3":
            mmm = "Mar";
            break;
        case "04":
        case "4":
            mmm = "Apr";
            break;
        case "05":
        case "5":
            mmm = "May";
            break;
        case "06":
        case "6":
            mmm = "Jun";
            break;
        case "07":
        case "7":
            mmm = "Jul";
            break;
        case "08":
        case "8":
            mmm = "Aug";
            break;
        case "09":
        case "9":
            mmm = "Sep";
            break;
        case "10":
            mmm = "Oct";
            break;
        case "11":
            mmm = "Nov";
            break;
        case "12":
            mmm = "Dec";
            break;
    }
    return mmm;
}

function CalculateAge(currentDate, birthDate, noOfDays) {
    var age = 0;

    if (IsValidDate(currentDate) && IsValidDate(birthDate)) {
        var dateOfBirth = parseDateNew(birthDate);
        var anniversaryDate = parseDateNew(currentDate);

        var calculateYear = anniversaryDate.getFullYear();
        var calculateMonth = anniversaryDate.getMonth();
        var calculateDay = anniversaryDate.getDate();

        var birthYear = dateOfBirth.getFullYear();
        var birthMonth = dateOfBirth.getMonth();
        var birthDay = dateOfBirth.getDate();

        age = calculateYear - birthYear;
        var ageMonth = calculateMonth - birthMonth;
        var ageDay = calculateDay - birthDay;

        if (ageMonth < 0 || (ageMonth == 0 && ageDay < 0)) {
            age = parseInt(age) - 1;
        }

        var lastBirthdayYear = calculateYear;
        var lastBirthdayMonth = birthMonth;
        var lastBirthdayDay = birthDay;

        //To calculate Last Birth date
        var lastBirthDate = new Date(lastBirthdayYear, lastBirthdayMonth, lastBirthdayDay);
        if (lastBirthDate > anniversaryDate) {
            lastBirthDate = new Date(calculateYear - 1, birthMonth, birthDay);
        }

        // To handle Age 0
        if (lastBirthDate < dateOfBirth) {
            lastBirthDate = new Date(birthYear, birthMonth, birthDay);
        }

        var diff = new Date(anniversaryDate - lastBirthDate);
        // get days               
        var days = diff / 1000 / 60 / 60 / 24;
        if (days > noOfDays) {
            age = age + 1;
        }
    }
    return age;
}

function IsValidDate(date) {
    if (typeof date === 'undefined' || date.length <= 0 || date.split('-').length != 3)
        return false;
    else
        return true;
}

function CalculateDOB(age) {
    var dt = new Date();
    var month = dt.getMonth() + 1;
    if (month.toString().length < 2) month = GetMonthMM(month.toString());
    var day = dt.getDate();
    if (day.toString().length < 2) day = '0' + day;
    var year = dt.getFullYear() - age;
    return (day + '-' + month + '-' + year);
}

$(document).ready(function () {
    $(".dateFormate").each(function (index, dateCtrl) {
        try {
            var date = $(dateCtrl).text();
            if (date.indexOf('T') > -1) {
                date = date.split('T')[0];
                var dtArr = date.split('-');
                date = dtArr[2] + "-" + dtArr[1] + "-" + dtArr[0];
            }
            $(dateCtrl).text(date);
        } catch (e) {

        }
    });

});


String.prototype.replaceAll = function (target, replacement) {
    return this.split(target).join(replacement);
};







