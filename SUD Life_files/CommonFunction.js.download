function CheckIsBlank(textToCheck) {
    if (typeof textToCheck === 'undefined' || textToCheck === null || textToCheck.length <= 0) {
        return true;
    } else {
        return false;
    }
}

function CheckTextStartWithNo(textToCheck) {
    if ((textToCheck.charCodeAt(0) >= 48) && (textToCheck.charCodeAt(0) <= 57)) {
