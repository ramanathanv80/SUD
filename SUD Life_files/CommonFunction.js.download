function FormatAmount(control) {
    $(control).each(function () {
        var tdval = "";
        if ($(this).is("input")) {
            tdval = $(this).val();
        }
        else {
            tdval = $(this).html();
        }
        if ($.isNumeric(tdval)) {
            var valueArray = tdval.split(".");
            var value = "";
            var decimal = "";
            if (valueArray.length > 1) {
                value = valueArray[0].toString();
                decimal = "." + valueArray[1].toString();
            }
            else {
                value = valueArray.toString();
            }
            if (value.length > 3) {
                if ($(this).is("input")) {
                    $(this).val(AddSeparater(value) + decimal);
                }
                else {
                    $(this).html(AddSeparater(value) + decimal);
                }
            }
        }
    });
}

function CurrencyFormat(amount) {
    var finalValue = amount;
    if ($.isNumeric(amount)) {
        var valueArray = amount.toString().split(".");
        var value = "";
        var decimal = "";
        if (valueArray.length > 1) {
            value = valueArray[0].toString();
            decimal = "." + valueArray[1].toString();
        }
        else {
            value = valueArray.toString();
        }
        if (value.length > 3) {
            finalValue = AddSeparater(value) + decimal;
        }
    }
    return finalValue;
}

function FormatAmountWithDecimal(str) {
    $(str).each(function () {
        var tdval = "";
        if ($(this).is("input")) {
            tdval = $(this).val();
        }
        else {
            tdval = $(this).html();
        }

        var replaceval = tdval.replaceAll(",", ""); //tdval.replace(/,/, '');
        var amount = parseFloat(replaceval).toFixed(2);
        var result = DecimalAddComma(amount);

        if ($(this).is("input")) {
            $(this).val(result);
        }
        else {
            $(this).html(result);
        }
    });

}

function DecimalAddComma(tdval) {
    var result = "";
    if ($.isNumeric(tdval)) {
        var valueArray = tdval.split(".");
        var value = "";
        var decimal = "";
        if (valueArray.length > 1) {
            value = valueArray[0].toString();
            decimal = "." + valueArray[1].toString();
        }
        else {
            value = valueArray.toString();
        }
        if (value.length > 3) {
            if ($(this).is("input")) {
                result = (AddSeparater(value) + decimal);
            }
            else {
                result = (AddSeparater(value) + decimal);
            }
        }
        else {
            result = tdval;
        }
    }
    return result;
}

function AddSeparater(obj) {
    var x = obj;
    x = x.toString();
    var lastThree = x.substring(x.length - 3);
    var otherNumbers = x.substring(0, x.length - 3);
    if (otherNumbers != '')
        lastThree = ',' + lastThree;
    var res = otherNumbers.replace(/\B(?=(\d{3})+(?!\d))/g, ",") + lastThree;
    return res;
}

