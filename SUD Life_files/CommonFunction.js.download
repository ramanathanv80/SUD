function CheckAnnuIncome(AnnuIncomeField, limitNum) {
    AnnuIncomeField = AnnuIncomeField.replaceAll(",", "");
    if (parseInt(AnnuIncomeField) <= 0 || parseInt(AnnuIncomeField) > 99999999999) {
        return false;
    }
    return true;
}

function CheckAnnuIncomeZero(AnnuIncomeField, limitNum) {
    
    AnnuIncomeField = AnnuIncomeField.replaceAll(",", "");
    if (parseInt(AnnuIncomeField) <= 0) {
        return false;
    }
    return true;
}

function CheckCharacterForNameWithDot(textToCheck) {
    var str = textToCheck;

    for (var i = 0; i < str.length; i++) {
        var ch = str.substring(i, i + 1);
        if ((ch < "a" || "z" < ch) && (ch < "A" || "Z" < ch) && (ch != ".")) {
            return false;
        }
    }
    return true;
}

