    else if (objVal == "2") {
        fnShowLoader("");
        window.location.href = "/HealthDetails/HealthDetails";
    }
    else if (objVal == "3") {
        fnShowLoader("");
        if (isPayNowSele == "1") {
            window.location.href = "/PaymentDetails/PaymentNowPage";
        }
        else {
            window.location.href = "/PaymentDetails/PaymentPage";
        }
    }
    else if (objVal == "4") {
        fnShowLoader("");
        window.location.href = "/UploadDoc/UploadDocuments";
    }
}

