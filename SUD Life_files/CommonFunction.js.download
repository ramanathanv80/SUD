function fnIndianFormatAmount(obj, textval) {
    var x = obj;
    x = x.toString();
    var lastThree = x.substring(x.length - 3);
    var otherNumbers = x.substring(0, x.length - 3);
    if (otherNumbers != '')
        lastThree = ',' + lastThree;
    var res = otherNumbers.replace(/\B(?=(\d{2})+(?!\d))/g, ",") + lastThree;
    //alert(res);
    $("#" + textval).val(res);
}

function fnFormatAmount(control) {
    $(control).each(function () {
        var tdval = "";
        if ($(this).is("input")) {
            tdval = $(this).val();
        }
        else {
            tdval = $(this).html();
        }
        if ($.isNumeric(tdval)) {
            var valueArray = tdval.split(".");
            var value = "";
            var decimal = "";
            if (valueArray.length > 1) {
                value = valueArray[0].toString();
                decimal = "." + valueArray[1].toString();
            }
            else {
                value = valueArray.toString();
            }
            if (value.length > 3) {
                if ($(this).is("input")) {
                    $(this).val(AddSeparater(value) + decimal);
                }
                else {
                    $(this).html(AddSeparater(value) + decimal);
                }
            }
        }
    });
}

function fnFormatAmountWithDecimal(str) {
    $(str).each(function () {
        var tdval = "";
        if ($(this).is("input")) {
            tdval = $(this).val();
        }
        else {
            tdval = $(this).html();
        }

        var replaceval = tdval.replaceAll(",", ""); //tdval.replace(/,/, '');
        var amount = parseFloat(replaceval).toFixed(2);
        var result = DecimalAddComma(amount);

        if ($(this).is("input")) {
            $(this).val(result);
        }
        else {
            $(this).html(result);
        }
    });
}

