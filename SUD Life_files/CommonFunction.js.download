function Sanitize(value) {
    var valueNew = DOMPurify.sanitize(value);

    if (value == valueNew) {
        return valueNew;
    }
    else {
        location.href = '/Error/ErrorStatus';
    }
}

function HasValue(value) {
    return (value.length > 0) ? true : false;
}


function ModalPremium(premFreq, annulizedPrem) {
    var modalPrem = 0;
    
    premFreq = parseInt(premFreq);
    annulizedPrem = annulizedPrem.replaceAll(",", "");
    if ($.isNumeric(premFreq) && $.isNumeric(annulizedPrem)) {
        if (premFreq == 4) {
            modalPrem = annulizedPrem * 0.0867;
        }
        else if (premFreq == 3) {
            modalPrem = annulizedPrem * 0.2582;
        }
        else if (premFreq == 2) {
            modalPrem = annulizedPrem * 0.5108;
        }
        else {
            modalPrem = parseFloat(annulizedPrem);
        }

        if (modalPrem > 0) {
            modalPrem = modalPrem.toFixed(2);
        }
    }

    return modalPrem;
}

function CheckIsValidateEmail(email) {
    var emailReg = new RegExp(/^(("[\w-\s]+")|([\w-]+(?:\.[\w-]+)*)|("[\w-\s]+")([\w-]+(?:\.[\w-]+)*))(@((?:[\w-]+\.)*\w[\w-]{0,66})\.([a-z]{2,6}(?:\.[a-z]{2})?)$)|(@\[?((25[0-5]\.|2[0-4][0-9]\.|1[0-9]{2}\.|[0-9]{1,2}\.))((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[0-9]{1,2})\.){2}(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[0-9]{1,2})\]?$)/i);
    return emailReg.test(email)
}

function CheckIsNumericValues(textToCheck) {
    try {
        var a = parseInt(textToCheck)
        var a = a * 2;
        if (isNaN(a)) {
            return false;
        }
        return true;
    } catch (e) {
        return false;
    }
}

