    var target = event.target;
    target.selectionStart = target.selectionEnd = target.value.length;
});


//////////////////***Financial Need Analysis***/////////////////////////////////////

function GetFutureValue(inflRate, noOfYears, currValue, isCompounding) {

    var fv = 0.0;

    if (currValue != 0) {

        var perYearRate = inflRate / 100;

        if (isCompounding == 'True') {

            for (var i = 0; i <= noOfYears; i++) {

                fv += currValue * Math.pow((1 + (perYearRate)), i);
            }
        }
        else {
            fv = currValue * Math.pow((1 + (perYearRate)), noOfYears);
        }
        fv = Math.round(fv);
    }
    return fv;
}
function GetFutureValueWithoutRounding(inflRate, noOfYears, currValue, isCompounding) {

    var fv = 0.0;

    if (currValue != 0) {

        var perYearRate = inflRate / 100;

        if (isCompounding == 'True') {

            for (var i = 0; i <= noOfYears; i++) {

                fv += currValue * Math.pow((1 + (perYearRate)), i);
            }
        }
        else {
            fv = currValue * Math.pow((1 + (perYearRate)), noOfYears);
        }
        //fv = Math.round(fv);
    }
    return fv;
}

function GetPresentValue(rate, noOfYears, payment, futureValue, dueAt) {
    var pv1 = 0, dTemp = 0, dTemp2 = 0, dtemp3 = 0;
    if (rate == 0) {
        return (-futureValue - (payment * noOfYears));
    }
    if (dueAt != 0) {
        dTemp = 1 + rate;
    }
    else {
        dTemp = 1;
    }
    dtemp3 = 1 + rate;
    dTemp2 = Math.pow(dtemp3, noOfYears);
    pv1 = Math.round((-(futureValue + payment * dTemp * ((dTemp2 - 1) / rate)) / dTemp2));
    return pv1;

}

function GetPresentValueOfFuturePayOuts(noOfPayouts, inflRate, growRate, amountNeeded) {
    var hlvValue = 0;
    var diff = growRate - inflRate;
    if (diff != 0) {
        var rate = diff / 100;
        var amount = -1 * amountNeeded;
        hlvValue = GetPresentValue(rate, noOfPayouts, amount, 0, 1);
    } else {
        var amount = noOfPayouts * amountNeeded;
        hlvValue = amount;
    }

    return hlvValue;
}

function GetFutureValueByLumsumInvestment(amountToInvest, growRate, noOfYears) {
    var perYearRate = parseFloat(growRate) / 100;
    return Math.round(amountToInvest * Math.pow(1 + parseFloat(perYearRate), parseInt(noOfYears)));
}

function GetFutureValueByYearlyInvestment(rate, nper, pmt, pv, type) {
    rate = rate / 100;
    var pow = Math.pow(1 + rate, nper),
        fv;
    if (rate) {
        fv = (pmt * (1 + rate * type) * (1 - pow) / rate) - pv * pow;
    } else {
        fv = -1 * (pv + pmt * nper);
    }
    return fv.toFixed();
}

function SetPieChat(differencePercentage) {
    var imageSource = "";
    if (differencePercentage > 0 && differencePercentage <= 10) {
        imageSource = "images/PG_10.png";
    }
    else if (differencePercentage > 10 && differencePercentage <= 20) {
        imageSource = "images/PG_20.png";
    }
    else if (differencePercentage > 20 && differencePercentage <= 30) {
        imageSource = "images/PG_30.png";
    }
    else if (differencePercentage > 30 && differencePercentage <= 40) {
        imageSource = "images/PG_40.png";
    }
    else if (differencePercentage > 40 && differencePercentage <= 50) {
        imageSource = "images/PG_50.png";
    }
    else if (differencePercentage > 50 && differencePercentage <= 60) {
        imageSource = "images/PG_60.png";
    }
    else if (differencePercentage > 60 && differencePercentage <= 70) {
        imageSource = "images/PG_70.png";
    }
    else if (differencePercentage > 70 && differencePercentage <= 80) {
        imageSource = "images/PG_80.png";
    }
    else if (differencePercentage > 80 && differencePercentage < 100) {
        imageSource = "images/PG_90.png";
    }
    else {
        imageSource = "images/PG_gap_100.png";
    }
    $("#imgPieChart").attr("src", imageSource);
}
