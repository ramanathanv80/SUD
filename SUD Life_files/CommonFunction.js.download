function getloader() {
    
    var val = window.location.href.split('/');
    var Urls = '';

  
    if (window.location.href.split('/')[3] == "Landing" && window.location.href.split('/')[4] != "LandingPageProceed") {
        ////localStorage.clear();
        localStorage.removeItem("loaderContent")
        Urls = 'Landing'
    }
    else {

        Urls = window.location.href.split('/')[3];
    }

    if (localStorage.getItem("loaderContent") == "" || localStorage.getItem("loaderContent") == null) {
        var ur = window.location.href.split(Urls)[0];

        $.ajax({
            type: "POST",
            contentType: "application/json;",
            url: window.location.href.split(Urls)[0] + '/ProductSelection/GetLoaderContent',
            success: function (result) {
                //var loaderCount = null;
                if (sessionStorage.getItem("loadCount") == "" || sessionStorage.getItem("loadCount") == null) {
                    sessionStorage.setItem("loadCount", "0");
                }

                var loaderCount = sessionStorage.getItem("loadCount");
                const loader = result.loaderList;//["Claim Settlement Ratio of 99.04%<sup>~</sup>", "Loading...", "Loading Please Wait..."];
                //for (var i = 0; i < loader.length; i++) {
                //    if (i == parseInt(loaderCount)) {
                $("#Loaderc").attr("data-text", loader[loaderCount].LoaderContent);
                $("#Loaderc").html(loader[loaderCount].LoaderContent);
                //    }
                //}

                let loadCon = JSON.stringify(loader)
                localStorage.setItem("loaderContent", loadCon)

                loaderCount = parseInt(loaderCount) + 1;
                sessionStorage.setItem("loadCount", loaderCount);
                if (loaderCount >= loader.length) {
                    sessionStorage.setItem("loadCount", "");
                }


            },
            error: function (err) {

                if (err.status == 401) {
                    location.href = window.location.href.split('HealthCombo')[0] + 'Session/SessionTimeOut';
                }
                else {
                    console.log(err);
                }

            }
        });
    }
    else {
        
        if (sessionStorage.getItem("loadCount") == "" || sessionStorage.getItem("loadCount") == null) {
            sessionStorage.setItem("loadCount", "0");
        }

        var loaderCount = sessionStorage.getItem("loadCount");
        let retString = localStorage.getItem("loaderContent");//["Claim Settlement Ratio of 99.04%<sup>~</sup>", "Loading...", "Loading Please Wait..."];
        let loader = JSON.parse(retString);
        //for (var i = 0; i < loader.length; i++) {
        //    if (i == parseInt(loaderCount)) {
        $("#Loaderc").attr("data-text", loader[loaderCount].LoaderContent);
        $("#Loaderc").html(loader[loaderCount].LoaderContent);
        //    }
        //}

        //let loadCon = JSON.stringify(loader)
        //localStorage.setItem("loaderContent", loadCon)

        loaderCount = parseInt(loaderCount) + 1;
        sessionStorage.setItem("loadCount", loaderCount);
        if (loaderCount >= loader.length) {
            sessionStorage.setItem("loadCount", "");
        }
    }


}

